---
import sql from "../lib/db.js";
import "../styles/admin.css";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const action = String(data.get("action") || "");

    if (action === "delete") {
      const id = Number(data.get("proyecto_id"));
      await sql`DELETE FROM proyecto_imagenes WHERE proyecto_id = ${id}`;
      await sql`DELETE FROM proyectos WHERE id = ${id}`;
    } else if (action === "create") {
      const titulo = String(data.get("titulo") || "");
      const categoria = String(data.get("categoria") || "");
      const descripcion = String(data.get("descripcion") || "");
      const imagenesBase64 = String(data.get("imagenes_base64") || "[]");

      const catRecord = await sql`SELECT id FROM categorias WHERE nombre = ${categoria} LIMIT 1`;
      const categoria_id = catRecord.length > 0 ? catRecord[0].id : null;

      const nuevoProyecto = await sql`
        INSERT INTO proyectos (titulo, categoria_id, descripcion, estado)
        VALUES (${titulo}, ${categoria_id}, ${descripcion}, 'Publicado')
        RETURNING id
      `;
      const proyecto_id = nuevoProyecto[0].id;

      const imagenes = JSON.parse(imagenesBase64);
      for (let i = 0; i < imagenes.length; i++) {
        await sql`
          INSERT INTO proyecto_imagenes (proyecto_id, ruta_imagen, es_portada, orden)
          VALUES (${proyecto_id}, ${imagenes[i]}, ${i === 0}, ${i})
        `;
      }
    }

    return Astro.redirect("/admin");
  } catch (error) {
    console.error("Error en la base de datos:", error);
  }
}

const proyectos = await sql`
  SELECT p.id, p.titulo, p.descripcion, c.nombre as categoria_nombre, i.ruta_imagen
  FROM proyectos p
  LEFT JOIN categorias c ON p.categoria_id = c.id
  LEFT JOIN proyecto_imagenes i ON p.id = i.proyecto_id AND i.es_portada = true
  ORDER BY p.creado_en DESC
`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Panel de Gestión | Vino & Arena</title>
  </head>
  <body>
    <div class="admin-layout">
      <aside class="sidebar">
        <div class="sidebar-header">
          <h1 class="admin-logo">Admin Panel</h1>
        </div>
        <nav class="sidebar-nav">
          <a href="/admin" class="active">Portafolio</a>
          <a href="/admin-hero" class="active">Principal</a>
          <a href="/admin-nosotros" class="active">Sobre Nosotros</a>
          <a href="/admin-servicios" class="active">Servicios</a>
          <a href="/admin-legado" class="active">Sección Legado</a>
          <a href="/admin-corporativo" class="active">Corporativo</a>
          <a href="/admin-cta" class="active">cuentanos tu vision</a>
        </nav>
      </aside>

      <main class="main-content">
        <header class="content-header">
          <h2>
            Inventario de Proyectos
            <span class="count">{proyectos.length} Eventos</span>
          </h2>
        </header>

        <div class="projects-grid">
          {proyectos.map((p) => (
            <div class="project-card">
              <div
                class="project-img"
                style={`background-image: url(${p.ruta_imagen || "https://via.placeholder.com/600"});`}
              />
              <div class="project-info">
                <span class="tag">{p.categoria_nombre || "Sin Categoría"}</span>
                <h3>{p.titulo}</h3>
                <p>{(p.descripcion || "").substring(0, 60)}...</p>
                <div class="card-actions" style="display: flex; gap: 10px; margin-top: 15px;">

                  <!-- ✅ BOTÓN EDITAR — ahora sí navega -->
                  <a
                    href={`/admin/editar/${p.id}`}
                    class="btn-edit"
                    style="flex: 1; padding: 8px; border: 1px solid #7A0016; color: #7A0016; background: transparent; cursor: pointer; border-radius: 4px; text-align: center; text-decoration: none; font-size: 0.9rem;"
                  >
                    Editar
                  </a>

                  <form
                    method="POST"
                    onsubmit="return confirm('¿Seguro que deseas eliminar este evento permanentemente?');"
                    style="flex: 1; margin: 0;"
                  >
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="proyecto_id" value={p.id} />
                    <button
                      type="submit"
                      class="btn-delete"
                      style="width: 100%; padding: 8px; border: 1px solid #ccc; background: transparent; cursor: pointer; border-radius: 4px; color: #333;"
                    >
                      Eliminar
                    </button>
                  </form>

                </div>
              </div>
            </div>
          ))}
        </div>
      </main>
    </div>

    <!-- MODAL NUEVO PROYECTO -->
    <div id="modal-proyecto" class="modal-overlay">
      <div class="modal-content">
        <div class="modal-header">
          <h3>Nuevo Proyecto</h3>
          <button type="button" class="btn-close" id="closeModal">&times;</button>
        </div>

        <form method="POST" class="admin-form" id="projectForm">
          <input type="hidden" name="action" value="create" />

          <div class="form-group">
            <label>Título del Proyecto</label>
            <input type="text" name="titulo" required placeholder="Ej: Gala Esmeralda 2024" />
          </div>
          <div class="form-group">
            <label>Categoría</label>
            <select name="categoria" required>
              <option value="Bodas de Autor">Bodas de Autor</option>
              <option value="Corporativo">Corporativo</option>
              <option value="Gala en Exterior">Gala en Exterior</option>
              <option value="Fiestas Temáticas">Fiestas Temáticas</option>
              <option value="Lanzamiento">Lanzamiento</option>
            </select>
          </div>
          <div class="form-group">
            <label>Descripción del Evento</label>
            <textarea name="descripcion" rows="4" required placeholder="Describe la atmósfera..."></textarea>
          </div>
          <div class="form-group">
            <label>Fotos (la primera será portada)</label>
            <div class="file-upload">
              <span>Haz clic para seleccionar fotos</span>
              <input type="file" id="projImages" multiple accept="image/*" />
            </div>
            <div class="gallery-preview" id="galleryPreview"></div>
          </div>

          <input type="hidden" name="imagenes_base64" id="imagenes_base64" value="[]" />

          <div class="form-actions">
            <button type="submit" class="btn-save">Guardar Proyecto</button>
          </div>
        </form>
      </div>
    </div>

    <script>
      const modal     = document.getElementById("modal-proyecto") as HTMLElement;
      const openBtn   = document.getElementById("openModal") as HTMLButtonElement;
      const closeBtn  = document.getElementById("closeModal") as HTMLButtonElement;
      const imageInput = document.getElementById("projImages") as HTMLInputElement;
      const previewContainer = document.getElementById("galleryPreview") as HTMLElement;
      const hiddenImagesInput = document.getElementById("imagenes_base64") as HTMLInputElement;

      let selectedImages: string[] = [];

      openBtn?.addEventListener("click", () => { modal.style.display = "flex"; });
      closeBtn?.addEventListener("click", () => { modal.style.display = "none"; });

      imageInput?.addEventListener("change", (e: Event) => {
        previewContainer.innerHTML = "";
        selectedImages = [];
        const files = (e.target as HTMLInputElement).files;
        if (!files) return;

        Array.from(files).forEach((file: File) => {
          const reader = new FileReader();
          reader.onload = (event: ProgressEvent<FileReader>) => {
            const result = event.target?.result as string;
            if (!result) return;
            selectedImages.push(result);
            hiddenImagesInput.value = JSON.stringify(selectedImages);
            const div = document.createElement("div");
            div.className = "preview-item";
            div.style.backgroundImage = `url(${result})`;
            div.style.backgroundSize = "cover";
            previewContainer.appendChild(div);
          };
          reader.readAsDataURL(file);
        });
      });
    </script>
  </body>
</html>