---
import sql from "../lib/db.js";
import "../styles/index.css";
import Footer from "./Footer.astro";

const identidadReq = await sql`SELECT * FROM identidad_marca LIMIT 1`;
const iden = identidadReq[0] || {
  cronica: "",
  mision: "",
  vision: "",
  ruta_imagen: "",
};

// Hero
await sql`
  CREATE TABLE IF NOT EXISTS seccion_hero (
    id SERIAL PRIMARY KEY,
    logo TEXT DEFAULT 'Vino & Arena',
    eyebrow TEXT DEFAULT 'Curaduría de Atmósferas',
    titulo_normal TEXT DEFAULT 'Creando',
    titulo_italico TEXT DEFAULT 'Atmósferas',
    titulo_normal2 TEXT DEFAULT 'que Inspiran el Alma.',
    descripcion TEXT DEFAULT 'Diseñamos entornos de lujo donde la estética impecable se encuentra con la emoción genuina. Cada espacio cuenta una historia única.',
    contador TEXT DEFAULT '2019 — Présente',
    imagen_principal TEXT DEFAULT 'https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=2098',
    imagen_acento TEXT DEFAULT 'https://images.unsplash.com/photo-1464366400600-7168b8af9bc3?q=80&w=1469'
  )
`;
await sql`INSERT INTO seccion_hero (id) VALUES (1) ON CONFLICT (id) DO NOTHING`;
const heroReq = await sql`SELECT * FROM seccion_hero WHERE id = 1`;
const hero = heroReq[0] || {
  logo: "Vino & Arena",
  eyebrow: "Curaduría de Atmósferas",
  titulo_normal: "Creando",
  titulo_italico: "Atmósferas",
  titulo_normal2: "que Inspiran el Alma.",
  descripcion:
    "Diseñamos entornos de lujo donde la estética impecable se encuentra con la emoción genuina. Cada espacio cuenta una historia única.",
  contador: "2019 — Présente",
  imagen_principal:
    "https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=2098",
  imagen_acento:
    "https://images.unsplash.com/photo-1464366400600-7168b8af9bc3?q=80&w=1469",
};

const servicios = await sql`
  SELECT * FROM servicios 
  WHERE estado = 'Activo' 
  ORDER BY id DESC 
  LIMIT 3
`;

const proyectos = await sql`
  SELECT p.id, p.titulo, c.nombre as cat, i.ruta_imagen
  FROM proyectos p
  LEFT JOIN categorias c ON p.categoria_id = c.id
  LEFT JOIN proyecto_imagenes i ON p.id = i.proyecto_id AND i.es_portada = true
  ORDER BY p.creado_en DESC 
  LIMIT 3
`;

const legadoReq = await sql`SELECT * FROM seccion_legado WHERE id = 1`;
const legado = legadoReq[0] || {
  titulo: "Un Legado de Elegancia Atemporal.",
  descripcion:
    "Creemos que un evento es mucho más que una reunión; es una obra de arte viva.",
  punto_1: "Diseño de autor exclusivo",
  punto_2: "Coordinación impecable",
  punto_3: "Experiencias multisensoriales",
  punto_4: "Atención personalizada 24/7",
  url_boton: "mailto:hola@vinoarena.com",
  ruta_imagen:
    "https://images.unsplash.com/photo-1429962714451-bb934ecdc4ec?q=80&w=2070",
  badge_titulo: "V & A",
  badge_subtitulo: "Legado de Elegancia Atemporal",
};

function normalizarUrl(url: string): string {
  if (!url) return "#";
  const u = url.trim();
  if (
    u.startsWith("http") ||
    u.startsWith("mailto:") ||
    u.startsWith("tel:") ||
    u.startsWith("#")
  )
    return u;
  if (/^[+]?[\d\s\-()]+$/.test(u)) return `tel:${u.replace(/\s/g, "")}`;
  if (u.includes("wa.me")) return `https://${u}`;
  return u;
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My love FEST</title>
    <meta
      name="description"
      content="Diseñamos entornos de lujo donde la estética impecable se encuentra con la emoción genuina."
    />
    <link rel="icon" type="image/png" href="/Logo.png" />
  </head>
  <body>
    <nav class="navbar" id="navbar">
      <a href="/" class="logo">{hero.logo || "Vino & Arena"}</a>
      <ul class="nav-links">
        <li><a href="#firma">La Firma</a></li>
        <li><a href="#experiencias">Experiencias</a></li>
        <li><a href="#archivo">Archivo</a></li>
        <li><a href="#contacto">Contacto</a></li>
      </ul>
      <a href="/proyectos" class="nav-cta">Colección</a>
    </nav>

    <header class="hero container">
      <div class="hero-content">
        <div class="hero-eyebrow reveal">
          <span>{hero.eyebrow}</span>
        </div>
        <h1 class="hero-title reveal reveal-delay-1">
          {hero.titulo_normal || "Creando"}
          <em>{hero.titulo_italico || "Atmósferas"}</em><br />{
            hero.titulo_normal2 || "que Inspiran el Alma."
          }
        </h1>
        <p class="hero-subtitle reveal reveal-delay-2">{hero.descripcion}</p>
        <div class="hero-actions reveal reveal-delay-3">
          <a href="#contacto" class="btn-primary"><span>Reservar Cita</span></a>
          <a href="/proyectos" class="btn-ghost">Ver Portafolio →</a>
        </div>
      </div>

      <div class="hero-visual reveal reveal-delay-2">
        <div class="hero-img-main">
          <img src={hero.imagen_principal} alt="Evento de lujo" />
        </div>
        <div class="hero-img-accent">
          <img src={hero.imagen_acento} alt="Detalles del evento" />
        </div>
        <span class="hero-counter">{hero.contador}</span>
      </div>

      <div class="scroll-indicator">
        <span>Scroll</span>
        <div class="scroll-line"></div>
      </div>
    </header>

    <section id="firma" class="firma-section">
      <div class="container">
        <div class="firma-grid">
          <div class="firma-img-wrap reveal">
            <!-- ✅ IMAGEN DINÁMICA DESDE BD -->
            <img
              src={iden.ruta_imagen ||
                "https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=2069"}
              alt="Nuestra Firma"
            />
          </div>
          <div>
            <p class="section-label reveal">La Firma</p>
            <h2 class="firma-title reveal reveal-delay-1">
              Un Atelier<br /><em>de Emociones.</em>
            </h2>
            <blockquote class="firma-cronica reveal reveal-delay-2">
              "{iden.cronica}"
            </blockquote>
            <div class="firma-pillars reveal reveal-delay-3">
              <div>
                <div class="pillar-label">Misión</div>
                <p class="pillar-text">{iden.mision}</p>
              </div>
              <div>
                <div class="pillar-label">Visión</div>
                <p class="pillar-text">{iden.vision}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="experiencias" class="experiencias-section">
      <div class="container">
        <div class="section-header reveal">
          <p class="section-label" style="justify-content: center;">
            Diseño y Producción de Élite
          </p>
          <h2 class="section-title">
            Experiencias <em style="font-style: italic; color: var(--wine);"
              >Curadas</em>
          </h2>
          <p class="section-sub">
            Bodas de autor y eventos corporativos de alto nivel
          </p>
        </div>

        <div class="grid-3">
          {
            servicios.map((s: any, i: number) => (
              <div class={`card-service reveal reveal-delay-${i + 1}`}>
                <span class="card-number">0{i + 1}</span>
                <img src={s.ruta_imagen || "/placeholder.jpg"} alt={s.titulo} />
                <div class="card-overlay">
                  <h3>{s.titulo}</h3>
                  <p>{s.descripcion.substring(0, 110)}...</p>
                  <div class="card-price">Desde ${s.precio_inicial} MXN</div>
                </div>
              </div>
            ))
          }
        </div>

        <div style="text-align: center; margin-top: 60px;" class="reveal">
          <a href="/servicios" class="ver-todo">Ver todos los servicios →</a>
        </div>
      </div>
    </section>

    <section id="archivo" class="archivo-section">
      <div class="container">
        <div class="archivo-header-row">
          <div>
            <p class="section-label reveal">Visual Storytelling</p>
            <h2 class="section-title reveal reveal-delay-1">
              El Archivo <em style="font-style: italic; color: var(--wine);"
                >Visual.</em>
            </h2>
            <p
              class="section-sub reveal reveal-delay-2"
              style="text-align: left; margin-top: 8px;"
            >
              Una selección de nuestras instalaciones más emblemáticas
            </p>
          </div>
          <a href="/proyectos" class="ver-todo reveal"
            >Ver todos los proyectos →</a
          >
        </div>

        <div class="grid-3">
          {
            proyectos.map((p: any, i: number) => (
              <a
                href={`/proyecto/${p.id}`}
                class={`project-item reveal reveal-delay-${i + 1}`}
              >
                <div class="project-img-box">
                  <img
                    src={p.ruta_imagen || "/placeholder.jpg"}
                    alt={p.titulo}
                  />
                </div>
                <span class="project-cat">{p.cat || "DISEÑO"}</span>
                <h3 class="project-title">{p.titulo}</h3>
              </a>
            ))
          }
        </div>

        <div class="archivo-cta reveal">
          <a
            href="/proyectos"
            class="btn-primary"
            style="display: inline-flex;"
          >
            <span>Explorar toda la colección</span>
          </a>
        </div>
      </div>
    </section>

    <section class="legado-section" id="contacto">
      <div class="container">
        <div class="legado-grid">
          <div class="legado-img reveal">
            <img src={legado.ruta_imagen} alt={legado.titulo} />
            <div class="legado-badge">
              <div class="legado-badge-title">
                {legado.badge_titulo || "V & A"}
              </div>
              <div class="legado-badge-sub">
                {legado.badge_subtitulo || "Legado de Elegancia Atemporal"}
              </div>
            </div>
          </div>
          <div class="legado-content reveal reveal-delay-2">
            <p class="section-label" style="color: var(--gold);">
              Trabajemos Juntos
            </p>
            <h2 class="legado-title" set:html={legado.titulo} />
            <p class="legado-text">{legado.descripcion}</p>
            <div class="legado-checks">
              {
                legado.punto_1 && (
                  <div class="legado-check">{legado.punto_1}</div>
                )
              }
              {
                legado.punto_2 && (
                  <div class="legado-check">{legado.punto_2}</div>
                )
              }
              {
                legado.punto_3 && (
                  <div class="legado-check">{legado.punto_3}</div>
                )
              }
              {
                legado.punto_4 && (
                  <div class="legado-check">{legado.punto_4}</div>
                )
              }
            </div>
            <a href={normalizarUrl(legado.url_boton)} class="btn-legado">
              <span>✦ Hablemos de su Próxima Visión</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <Footer />

    <script>
      const navbar = document.getElementById("navbar");
      window.addEventListener("scroll", () => {
        navbar?.classList.toggle("scrolled", window.scrollY > 40);
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add("active");
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
      );
      document
        .querySelectorAll(".reveal")
        .forEach((el) => observer.observe(el));

      const hamburger = document.getElementById("hamburger");
      const mobileMenu = document.getElementById("mobileMenu");

      function openMenu() {
        hamburger?.classList.add("open");
        mobileMenu?.classList.add("open");
        document.body.style.overflow = "hidden";
      }
      function closeMenu() {
        hamburger?.classList.remove("open");
        mobileMenu?.classList.remove("open");
        document.body.style.overflow = "";
      }
      hamburger?.addEventListener("click", () => {
        if (hamburger.classList.contains("open")) closeMenu();
        else openMenu();
      });
      document.querySelectorAll("[data-close]").forEach((link) => {
        link.addEventListener("click", closeMenu);
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeMenu();
      });
    </script>
  </body>
</html>
