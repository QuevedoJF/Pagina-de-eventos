---
import Layout from "../layouts/Layout.astro";
---

<Layout title="LuxeEvents | Inicio">
  <header class="navbar">
    <div class="logo">Pagina de Eventos</div>
  </header>

  <main>
    <section class="hero">
      <span class="eyebrow">THE CURATED ATMOSPHERE</span>
      <h1>Elevando<br />Momentos a Obras<br />Maestras.</h1>
      <p>
        Estilismo y coordinación de eventos de lujo para quienes exigen la
        excelencia. Transformamos espacios en experiencias inolvidables.
      </p>

      <div class="cta-buttons">
        <a href="#contacto" class="btn btn-primary">Consultar Ahora</a>
        <a href="#portafolio" class="btn btn-outline">Ver Nuestro Trabajo</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .navbar {
    padding: 2rem;
    text-align: center;
  }
  .logo {
    font-family: "Georgia", serif;
    font-size: 1.5rem;
    color: var(--texto-oscuro);
  }
  .hero {
    padding: 4rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .eyebrow {
    font-size: 0.8rem;
    letter-spacing: 2px;
    color: var(--texto-gris);
  }
  .hero h1 {
    font-size: 2.8rem;
    margin: 0;
    line-height: 1.1;
    color: var(--texto-oscuro);
  }
  .hero p {
    color: var(--texto-gris);
    max-width: 600px;
    line-height: 1.6;
    font-size: 1.1rem;
  }
  .cta-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 300px;
    margin-top: 1rem;
  }
  .btn {
    padding: 1rem;
    text-decoration: none;
    text-align: center;
    font-size: 1rem;
    transition: all 0.3s ease;
  }
  .btn-primary {
    background-color: var(--color-vino);
    color: white;
  }
  .btn-outline {
    background-color: transparent;
    color: var(--texto-oscuro);
    border: 1px solid var(--texto-oscuro);
  }
</style>
