---
import sql from "../lib/db.js";
import "../styles/admin.css";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const cronica = String(data.get("cronica") || "");
    const mision = String(data.get("mision") || "");
    const vision = String(data.get("vision") || "");
    const imagen = String(data.get("imagen_base64") || "");

    const fechaAhora = new Date();
    const usuarioActivo = "Administrador";

    // Asegurar columna imagen existe
    await sql`ALTER TABLE identidad_marca ADD COLUMN IF NOT EXISTS ruta_imagen TEXT DEFAULT 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=2069'`;

    const check = await sql`SELECT id FROM identidad_marca LIMIT 1`;
    if (check.length > 0) {
      await sql`
        UPDATE identidad_marca 
        SET cronica  = ${cronica},
            mision   = ${mision},
            vision   = ${vision},
            ruta_imagen = ${imagen !== "" ? imagen : sql`ruta_imagen`},
            ultima_modificacion = ${fechaAhora},
            editado_por = ${usuarioActivo}
      `;
    } else {
      await sql`
        INSERT INTO identidad_marca (cronica, mision, vision, ruta_imagen, ultima_modificacion, editado_por)
        VALUES (${cronica}, ${mision}, ${vision}, ${imagen}, ${fechaAhora}, ${usuarioActivo})
      `;
    }
    return Astro.redirect("/admin-nosotros?ok=1");
  } catch (error) {
    console.error("Error al guardar:", error);
  }
}

const identidadReq = await sql`SELECT * FROM identidad_marca LIMIT 1`;
const identidad = identidadReq[0] || {
  cronica: "",
  mision: "",
  vision: "",
  ruta_imagen:
    "https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=2069",
  ultima_modificacion: null,
  editado_por: "Sin registros",
};

const fechaValida =
  identidad.ultima_modificacion &&
  !isNaN(new Date(identidad.ultima_modificacion).getTime())
    ? new Date(identidad.ultima_modificacion)
    : new Date();

const fechaFormateada = new Intl.DateTimeFormat("es-ES", {
  day: "2-digit",
  month: "short",
  year: "numeric",
}).format(fechaValida);

const showOk = Astro.url.searchParams.get("ok") === "1";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Editor Sobre Nosotros | Admin</title>
    <link rel="icon" type="image/png" href="/Logo.png" />
  </head>
  <body style="background-color: #f9f8f4;">
    <div class="admin-layout">
      <aside class="sidebar">
        <div class="sidebar-header">
          <h1 class="admin-logo">Admin Panel</h1>
        </div>
        <nav class="sidebar-nav">
          <a href="/admin">Portafolio</a>
          <a href="/admin-hero">Principal</a>
          <a href="/admin-nosotros" class="active">Sobre Nosotros</a>
          <a href="/admin-servicios">Servicios</a>
          <a href="/admin-legado">Sección Legado</a>
          <a href="/admin-corporativo">Corporativo</a>
        </nav>
      </aside>

      <main class="main-content">
        <header class="content-header">
          <h2 style="font-family: 'Playfair Display', serif; font-size: 2rem;">
            Sobre Nosotros
          </h2>
          {
            showOk && (
              <div style="margin-top: 14px; background: #e6f4ea; border: 1px solid #4caf50; color: #2e7d32; padding: 12px 20px; border-radius: 6px; font-size: 0.88rem;">
                ✓ Cambios guardados correctamente
              </div>
            )
          }
        </header>

        <form method="POST">
          <input type="hidden" name="imagen_base64" id="field-img-base64" />

          <div class="editor-layout" style="grid-template-columns: 1fr 350px;">
            <div class="editor-main">
              <div class="editor-card">
                <h3>Nuestra Historia</h3>
                <textarea name="cronica" class="editor-textarea" required
                  >{identidad.cronica}</textarea
                >
              </div>
              <div class="card-row">
                <div class="editor-card">
                  <h3>Misión</h3>
                  <textarea name="mision" class="editor-textarea small" required
                    >{identidad.mision}</textarea
                  >
                </div>
                <div class="editor-card">
                  <h3>Visión</h3>
                  <textarea name="vision" class="editor-textarea small" required
                    >{identidad.vision}</textarea
                  >
                </div>
              </div>
            </div>

            <div class="editor-sidebar">
              <div class="action-buttons">
                <button
                  type="button"
                  class="btn-discard"
                  onclick="window.location.reload();">DESCARTAR</button
                >
                <button type="submit" class="btn-publish"
                  >PUBLICAR CAMBIOS</button
                >
              </div>

              <!-- IMAGEN DE LA FIRMA -->
              <div class="editor-card" style="margin-top: 20px;">
                <h3>Imagen de La Firma</h3>
                <p
                  style="font-size: 0.78rem; color: #999; margin-bottom: 12px;"
                >
                  Foto que aparece a la izquierda en la sección "La Firma".
                </p>
                <div
                  id="img-preview"
                  style={`width: 100%; height: 200px; background-image: url('${identidad.ruta_imagen || ""}'); background-size: cover; background-position: center; border-radius: 8px; margin-bottom: 12px; background-color: #eee;`}
                >
                </div>
                <input
                  type="file"
                  id="file-input"
                  accept="image/*"
                  style="font-size: 0.8rem;"
                />
              </div>

              <div class="editor-card" style="margin-top: 20px;">
                <h3>ESTADO DE PUBLICACIÓN</h3>
                <div style="margin: 15px 0;">
                  <span class="status-badge">● Publicado en Web</span>
                </div>
                <div class="meta-info">
                  <p>Última modificación<br /><span>{fechaFormateada}</span></p>
                  <p>Editado por<br /><span>{identidad.editado_por}</span></p>
                </div>
              </div>
            </div>
          </div>
        </form>
      </main>
    </div>

    <script>
      const imgInput = document.getElementById(
        "file-input",
      ) as HTMLInputElement;
      const hiddenImg = document.getElementById(
        "field-img-base64",
      ) as HTMLInputElement;
      const preview = document.getElementById("img-preview") as HTMLElement;

      imgInput?.addEventListener("change", () => {
        const file = imgInput.files?.[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (e) => {
          const base64 = e.target?.result as string;
          hiddenImg.value = base64;
          preview.style.backgroundImage = `url(${base64})`;
        };
        reader.readAsDataURL(file);
      });
    </script>
  </body>
</html>
