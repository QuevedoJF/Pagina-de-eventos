---
import sql from "../../../lib/db.js";
import "../../../styles/admin.css";

const { id } = Astro.params;
const proyectoId = Number(id);
let saveError = "";

// ── ELIMINAR IMAGEN DE GALERÍA ─────────────────
if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const accion = String(data.get("accion") || "");

  // Eliminar imagen individual
  if (accion === "eliminar_imagen") {
    const imgId = Number(data.get("imagen_id"));
    await sql`DELETE FROM proyecto_imagenes WHERE id = ${imgId} AND proyecto_id = ${proyectoId}`;
    return Astro.redirect(`/admin/editar/${id}?ok=img_eliminada`);
  }

  // Marcar como portada
  if (accion === "set_portada") {
    const imgId = Number(data.get("imagen_id"));
    await sql`UPDATE proyecto_imagenes SET es_portada = false WHERE proyecto_id = ${proyectoId}`;
    await sql`UPDATE proyecto_imagenes SET es_portada = true  WHERE id = ${imgId}`;
    return Astro.redirect(`/admin/editar/${id}?ok=portada`);
  }

  // Agregar nuevas imágenes
  if (accion === "agregar_imagenes") {
    const imagenes = data.getAll("nuevas_imagenes[]");
    for (const img of imagenes) {
      const base64 = String(img);
      if (base64) {
        await sql`
          INSERT INTO proyecto_imagenes (proyecto_id, ruta_imagen, es_portada)
          VALUES (${proyectoId}, ${base64}, false)
        `;
      }
    }
    return Astro.redirect(`/admin/editar/${id}?ok=imagenes`);
  }

  // Guardar datos del proyecto
  if (accion === "guardar_proyecto") {
    try {
      const titulo = String(data.get("titulo") || "");
      const descripcion = String(data.get("descripcion") || "");
      const categoria = String(data.get("categoria_id") || "");

      await sql`
        UPDATE proyectos
        SET titulo = ${titulo},
            descripcion = ${descripcion},
            categoria_id = ${categoria ? Number(categoria) : null}
        WHERE id = ${proyectoId}
      `;
      return Astro.redirect(`/admin/editar/${id}?ok=1`);
    } catch (e: any) {
      saveError = e?.message || "Error al guardar";
    }
  }
}

// ── OBTENER DATOS ──────────────────────────────
const proyectoReq = await sql`SELECT * FROM proyectos WHERE id = ${proyectoId}`;
const proyecto = proyectoReq[0];
if (!proyecto) return Astro.redirect("/admin");

const categorias = await sql`SELECT * FROM categorias ORDER BY nombre ASC`;
const imagenes = await sql`
  SELECT * FROM proyecto_imagenes 
  WHERE proyecto_id = ${proyectoId} 
  ORDER BY es_portada DESC, id ASC
`;

const msg = Astro.url.searchParams.get("ok");
const mensajes: Record<string, string> = {
  "1": "✓ Proyecto guardado correctamente",
  img_eliminada: "✓ Imagen eliminada",
  portada: "✓ Portada actualizada",
  imagenes: "✓ Imágenes agregadas",
};
const showMsg = msg ? mensajes[msg] : null;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Editar Proyecto | Admin</title>
    <style>
      .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 16px;
        margin-top: 20px;
      }
      .gallery-item {
        position: relative;
        aspect-ratio: 4/3;
        border-radius: 8px;
        overflow: hidden;
        background: #eee;
        border: 2px solid transparent;
        transition: border-color 0.2s;
      }
      .gallery-item.portada {
        border-color: #6b1528;
      }
      .gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .gallery-item-actions {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.55);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        opacity: 0;
        transition: opacity 0.2s;
      }
      .gallery-item:hover .gallery-item-actions {
        opacity: 1;
      }
      .gallery-item-actions button {
        background: white;
        border: none;
        padding: 6px 14px;
        font-size: 0.72rem;
        letter-spacing: 1px;
        cursor: pointer;
        border-radius: 4px;
        width: 130px;
        font-weight: 500;
        transition: background 0.2s;
      }
      .gallery-item-actions button.btn-portada {
        color: #6b1528;
      }
      .gallery-item-actions button.btn-eliminar {
        color: #c62828;
      }
      .gallery-item-actions button:hover {
        background: #f5f0eb;
      }
      .portada-badge {
        position: absolute;
        top: 8px;
        left: 8px;
        background: #6b1528;
        color: white;
        font-size: 0.58rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 3px 8px;
        border-radius: 3px;
      }
      .upload-zone {
        border: 2px dashed #ddd;
        border-radius: 10px;
        padding: 40px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;
        background: #fafafa;
        margin-top: 20px;
      }
      .upload-zone:hover,
      .upload-zone.dragover {
        border-color: #6b1528;
        background: #fdf5f6;
      }
      .upload-zone input {
        display: none;
      }
      .upload-zone p {
        color: #999;
        font-size: 0.85rem;
        margin-top: 10px;
      }
      .upload-queue {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 12px;
        margin-top: 16px;
      }
      .queue-item {
        position: relative;
        aspect-ratio: 4/3;
        border-radius: 6px;
        overflow: hidden;
        border: 1px solid #eee;
      }
      .queue-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .queue-item button {
        position: absolute;
        top: 4px;
        right: 4px;
        background: rgba(198, 40, 40, 0.85);
        color: white;
        border: none;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        cursor: pointer;
        font-size: 11px;
        line-height: 1;
      }
    </style>
  </head>
  <body style="background-color: #f9f8f4;">
    <div class="admin-layout">
      <aside class="sidebar">
        <div class="sidebar-header">
          <h1 class="admin-logo">Admin Panel</h1>
        </div>
        <nav class="sidebar-nav">
          <a href="/admin" class="active">Portafolio</a>
          <a href="/admin-nosotros">Sobre Nosotros</a>
          <a href="/admin-servicios">Servicios</a>
          <a href="/admin-legado">Sección Legado</a>
          <a href="/admin-corporativo">Corporativo</a>
          <a href="/admin-cta">Sección Contacto</a>
        </nav>
      </aside>

      <main class="main-content">
        <header class="content-header">
          <div style="display: flex; align-items: center; gap: 16px;">
            <a
              href="/admin"
              style="color: #999; text-decoration: none; font-size: 0.85rem;"
              >← Volver</a
            >
            <h2
              style="font-family: 'Playfair Display', serif; font-size: 2rem;"
            >
              Editar Proyecto
            </h2>
          </div>

          {
            showMsg && (
              <div style="margin-top: 14px; background: #e6f4ea; border: 1px solid #4caf50; color: #2e7d32; padding: 12px 20px; border-radius: 6px; font-size: 0.88rem;">
                {showMsg}
              </div>
            )
          }
          {
            saveError && (
              <div style="margin-top: 14px; background: #fdecea; border: 1px solid #f44336; color: #c62828; padding: 12px 20px; border-radius: 6px; font-size: 0.85rem;">
                <strong>Error:</strong> {saveError}
              </div>
            )
          }
        </header>

        <div
          class="editor-layout"
          style="grid-template-columns: 1fr 380px; margin-top: 32px;"
        >
          <!-- ── COLUMNA IZQUIERDA ─────────────── -->
          <div class="editor-main">
            <!-- Datos del proyecto -->
            <form method="POST">
              <input type="hidden" name="accion" value="guardar_proyecto" />
              <div class="editor-card">
                <h3>Datos del Proyecto</h3>
                <div class="form-group">
                  <label>Título</label>
                  <input
                    type="text"
                    name="titulo"
                    value={proyecto.titulo}
                    required
                  />
                </div>
                <div class="form-group">
                  <label>Descripción</label>
                  <textarea name="descripcion" rows="4"
                    >{proyecto.descripcion}</textarea
                  >
                </div>
                <div class="form-group">
                  <label>Categoría</label>
                  <select
                    name="categoria_id"
                    style="width:100%; padding: 10px 14px; border: 1px solid #e8e2d9; border-radius: 6px; background: #fafaf8; font-family: inherit; font-size: 0.9rem;"
                  >
                    <option value="">Sin categoría</option>
                    {
                      categorias.map((c: any) => (
                        <option
                          value={c.id}
                          selected={c.id === proyecto.categoria_id}
                        >
                          {c.nombre}
                        </option>
                      ))
                    }
                  </select>
                </div>
                <button
                  type="submit"
                  class="btn-publish"
                  style="margin-top: 10px;"
                >
                  GUARDAR DATOS
                </button>
              </div>
            </form>

            <!-- Galería de imágenes -->
            <div class="editor-card" style="margin-top: 24px;">
              <h3>Galería de Imágenes</h3>
              <p style="color: #999; font-size: 0.82rem; margin-bottom: 4px;">
                {imagenes.length} imagen{imagenes.length !== 1 ? "es" : ""} · La imagen
                con borde vino es la portada
              </p>

              {
                imagenes.length === 0 && (
                  <div style="text-align: center; padding: 40px; color: #bbb; font-size: 0.85rem;">
                    No hay imágenes aún. Agrega desde el panel derecho.
                  </div>
                )
              }

              <div class="gallery-grid">
                {
                  imagenes.map((img: any) => (
                    <div
                      class={`gallery-item ${img.es_portada ? "portada" : ""}`}
                    >
                      <img src={img.ruta_imagen} alt="Imagen del proyecto" />
                      {img.es_portada && (
                        <span class="portada-badge">Portada</span>
                      )}
                      <div class="gallery-item-actions">
                        {!img.es_portada && (
                          <form method="POST">
                            <input
                              type="hidden"
                              name="accion"
                              value="set_portada"
                            />
                            <input
                              type="hidden"
                              name="imagen_id"
                              value={img.id}
                            />
                            <button type="submit" class="btn-portada">
                              ⭐ Usar de portada
                            </button>
                          </form>
                        )}
                        <form
                          method="POST"
                          onsubmit="return confirm('¿Eliminar esta imagen?')"
                        >
                          <input
                            type="hidden"
                            name="accion"
                            value="eliminar_imagen"
                          />
                          <input
                            type="hidden"
                            name="imagen_id"
                            value={img.id}
                          />
                          <button type="submit" class="btn-eliminar">
                            ✕ Eliminar
                          </button>
                        </form>
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>

          <!-- ── COLUMNA DERECHA ──────────────── -->
          <div class="editor-sidebar">
            <div class="editor-card">
              <h3>Agregar Imágenes</h3>
              <p style="color: #999; font-size: 0.82rem; margin-bottom: 4px;">
                Selecciona una o varias fotos a la vez.
              </p>

              <!-- Upload zone -->
              <div class="upload-zone" id="upload-zone">
                <input type="file" id="file-picker" accept="image/*" multiple />
                <div style="font-size: 2rem;">🖼️</div>
                <p><strong>Haz clic o arrastra</strong> las imágenes aquí</p>
                <p>JPG, PNG, WEBP · Múltiples archivos permitidos</p>
              </div>

              <!-- Queue preview -->
              <div class="upload-queue" id="upload-queue"></div>

              <!-- Hidden form to submit -->
              <form method="POST" id="upload-form" style="margin-top: 16px;">
                <input type="hidden" name="accion" value="agregar_imagenes" />
                <div id="hidden-inputs"></div>
                <button
                  type="submit"
                  id="btn-subir"
                  class="btn-publish"
                  style="width: 100%; display: none;"
                >
                  SUBIR IMÁGENES (<span id="count">0</span>)
                </button>
              </form>
            </div>

            <!-- Info -->
            <div
              class="editor-card"
              style="margin-top: 20px; background: #fdf5f6; border: 1px solid #f0d0d5;"
            >
              <h3 style="color: #6B1528;">Guía rápida</h3>
              <ul
                style="font-size: 0.82rem; color: #666; line-height: 2; padding-left: 16px;"
              >
                <li>
                  La <strong>portada</strong> aparece en la galería principal
                </li>
                <li>Puedes subir <strong>múltiples fotos</strong> a la vez</li>
                <li>Pasa el cursor sobre una foto para ver opciones</li>
                <li>Puedes cambiar la portada en cualquier momento</li>
              </ul>
            </div>
          </div>
        </div>
      </main>
    </div>

    <script>
      const zone = document.getElementById("upload-zone") as HTMLElement;
      const picker = document.getElementById("file-picker") as HTMLInputElement;
      const queue = document.getElementById("upload-queue") as HTMLElement;
      const hidden = document.getElementById("hidden-inputs") as HTMLElement;
      const btnSubir = document.getElementById(
        "btn-subir",
      ) as HTMLButtonElement;
      const countEl = document.getElementById("count") as HTMLElement;

      let pendingFiles: { name: string; base64: string }[] = [];

      function updateCount() {
        countEl.textContent = String(pendingFiles.length);
        btnSubir.style.display = pendingFiles.length > 0 ? "block" : "none";
      }

      function renderQueue() {
        queue.innerHTML = "";
        hidden.innerHTML = "";
        pendingFiles.forEach((f, i) => {
          // Visual thumbnail
          const div = document.createElement("div");
          div.className = "queue-item";
          div.innerHTML = `
            <img src="${f.base64}" alt="${f.name}" />
            <button type="button" data-i="${i}">✕</button>
          `;
          div.querySelector("button")?.addEventListener("click", () => {
            pendingFiles.splice(i, 1);
            renderQueue();
            updateCount();
          });
          queue.appendChild(div);

          // Hidden input
          const inp = document.createElement("input");
          inp.type = "hidden";
          inp.name = "nuevas_imagenes[]";
          inp.value = f.base64;
          hidden.appendChild(inp);
        });
        updateCount();
      }

      async function processFiles(files: FileList | null) {
        if (!files) return;
        for (const file of Array.from(files)) {
          const base64 = await new Promise<string>((res) => {
            const r = new FileReader();
            r.onload = (e) => res(e.target?.result as string);
            r.readAsDataURL(file);
          });
          pendingFiles.push({ name: file.name, base64 });
        }
        renderQueue();
      }

      // Click to open file picker
      zone.addEventListener("click", () => picker.click());
      picker.addEventListener("change", () => processFiles(picker.files));

      // Drag and drop
      zone.addEventListener("dragover", (e) => {
        e.preventDefault();
        zone.classList.add("dragover");
      });
      zone.addEventListener("dragleave", () =>
        zone.classList.remove("dragover"),
      );
      zone.addEventListener("drop", (e) => {
        e.preventDefault();
        zone.classList.remove("dragover");
        processFiles(e.dataTransfer?.files || null);
      });
    </script>
  </body>
</html>
